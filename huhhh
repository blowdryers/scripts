$ports = 1..65535
$jobs = foreach ($p in $ports) {
    Start-Job -ScriptBlock {
        param($port)
        try {
            $client = New-Object System.Net.Sockets.TcpClient
            $client.Connect("127.0.0.1",$port)
            if ($client.Connected) {
                "Port $port is open"
                $client.Close()
            }
        } catch {}
    } -ArgumentList $p
}

$jobs | Wait-Job | Receive-Job